# TGOS authentication
# Use strong, unique passwords in local development and deployment environments.

TGOS_OWNER_USERNAME=don
TGOS_OWNER_PASSWORD=replace-with-a-strong-owner-password

TGOS_MARKETING_USERNAME=scott
TGOS_MARKETING_PASSWORD=replace-with-a-strong-marketing-password

# Generate a long random value. Do not reuse a user password.
TGOS_SESSION_SECRET=replace-with-a-long-random-session-secret

# Backward compatibility only. Existing deployments may continue using these
# until TGOS_OWNER_USERNAME and TGOS_OWNER_PASSWORD are configured.
# TGOS_USERNAME=
# TGOS_PASSWORD=
